[
  {
    "controlId": "CR-AWS-OPENSEARCH-001",
    "cases": [
      {
        "name": "encryption at rest enabled",
        "expected": "pass",
        "records": [
          {
            "collectorId": "aws.opensearch.describe_domain",
            "region": "us-east-1",
            "resourceKey": "prod-logs",
            "exitCode": 0,
            "output": {
              "DomainStatus": {
                "DomainId": "111122223333/prod-logs",
                "DomainName": "prod-logs",
                "ARN": "arn:aws:es:us-east-1:111122223333:domain/prod-logs",
                "EncryptionAtRestOptions": {
                  "Enabled": true,
                  "KmsKeyId": "arn:aws:kms:us-east-1:111122223333:key/abcd"
                }
              }
            }
          }
        ]
      },
      {
        "name": "encryption at rest disabled",
        "expected": "fail",
        "records": [
          {
            "collectorId": "aws.opensearch.describe_domain",
            "region": "us-east-1",
            "resourceKey": "dev-logs",
            "exitCode": 0,
            "output": {
              "DomainStatus": {
                "DomainName": "dev-logs",
                "ARN": "arn:aws:es:us-east-1:111122223333:domain/dev-logs",
                "EncryptionAtRestOptions": {
                  "Enabled": false
                }
              }
            }
          }
        ]
      },
      {
        "name": "domain deleted mid-scan",
        "expected": "not_applicable",
        "records": [
          {
            "collectorId": "aws.opensearch.describe_domain",
            "region": "us-east-1",
            "resourceKey": "gone",
            "exitCode": 254,
            "output": null,
            "errorText": "An error occurred (ResourceNotFoundException) when calling the DescribeDomain operation: Domain not found: gone"
          }
        ]
      }
    ]
  },
