        "records": [
          {
            "collectorId": "azure.keyvault.show",
            "resourceKey": "kv-legacy",
            "exitCode": 0,
            "output": {
              "name": "kv-legacy",
              "properties": {
                "enableRbacAuthorization": false,
                "accessPolicies": [
                  {
                    "objectId": "00000000-0000-0000-0000-000000000001",
                    "permissions": {
                      "secrets": [
                        "get",
                        "list"
                      ]
                    }
                  }
                ]
              }
            }
          }
        ]
      }
    ]
