  {
    "controlId": "CR-AZURE-KEYVAULT-150",
    "cases": [
      {
        "name": "all keys have expiry",
        "expected": "pass",
        "records": [
          {
            "collectorId": "azure.keyvault.key_list",
            "resourceKey": "kv-prod",
            "exitCode": 0,
            "output": [
              {
                "kid": "https://kv-prod.vault.azure.net/keys/enc",
                "managed": false,
                "attributes": {
                  "enabled": true,
                  "created": "2025-01-01T00:00:00+00:00",
                  "expires": "2027-01-01T00:00:00+00:00"
                }
              },
              {
                "kid": "https://kv-prod.vault.azure.net/keys/sign",
                "managed": false,
                "attributes": {
                  "enabled": true,
                  "created": "2025-01-01T00:00:00+00:00",
                  "expires": "2027-06-01T00:00:00+00:00"
                }
              }
            ]
          }
        ]
      },
      {
        "name": "one key without expiry",
        "expected": "fail",
        "records": [
          {
            "collectorId": "azure.keyvault.key_list",
            "resourceKey": "kv-dev",
            "exitCode": 0,
            "output": [
              {
                "kid": "https://kv-dev.vault.azure.net/keys/enc",
                "managed": false,
                "attributes": {
                  "enabled": true,
                  "created": "2025-01-01T00:00:00+00:00",
                  "expires": "2027-01-01T00:00:00+00:00"
                }
              },
              {
                "kid": "https://kv-dev.vault.azure.net/keys/legacy",
                "managed": false,
                "attributes": {
                  "enabled": true,
                  "created": "2020-01-01T00:00:00+00:00"
                }
              }
            ]
          }
        ]
      },
      {
        "name": "no data-plane permission",
        "expected": "error",
        "records": [
          {
            "collectorId": "azure.keyvault.key_list",
            "resourceKey": "kv-locked",
            "exitCode": 1,
            "output": null,
            "errorText": "(Forbidden) The user, group or application does not have keys list permission on key vault 'kv-locked'."
          }
        ]
      }
    ]
  },
