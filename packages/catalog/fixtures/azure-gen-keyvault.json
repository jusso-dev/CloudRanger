  {
    "controlId": "CR-AZURE-KEYVAULT-100",
    "cases": [
      {
        "name": "passes with rbac enabled",
        "expected": "pass",
        "records": [
          {
            "collectorId": "azure.keyvault.show",
            "resourceKey": "kv-prod",
            "exitCode": 0,
            "output": {
              "name": "kv-prod",
              "properties": {
                "enableRbacAuthorization": true,
                "enableSoftDelete": true
              }
            }
          }
        ]
      },
      {
        "name": "fails with legacy access policies",
