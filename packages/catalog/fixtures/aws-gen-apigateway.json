      {
        "name": "all stages have access log destination",
        "expected": "pass",
        "records": [
          {
            "collectorId": "aws.apigateway.get_stages",
            "region": "us-east-1",
            "resourceKey": "abc123",
            "exitCode": 0,
            "output": {
              "item": [
                {
                  "stageName": "prod",
                  "deploymentId": "d1",
                  "accessLogSettings": {
                    "format": "$context.requestId",
                    "destinationArn": "arn:aws:logs:us-east-1:111122223333:log-group:api-access"
                  }
                }
              ]
            }
          }
        ]
      },
      {
        "name": "stage missing access log settings",
        "expected": "fail",
        "records": [
          {
            "collectorId": "aws.apigateway.get_stages",
