[
  {
    "controlId": "CR-AWS-IAM-001",
    "cases": [
      {
        "name": "passes when root MFA enabled",
        "expected": "pass",
        "records": [
          {
            "collectorId": "aws.iam.get_account_summary",
            "exitCode": 0,
            "output": { "SummaryMap": { "AccountMFAEnabled": 1, "AccountAccessKeysPresent": 0 } }
          }
        ]
      },
      {
        "name": "fails when root MFA disabled",
        "expected": "fail",
        "records": [
          {
            "collectorId": "aws.iam.get_account_summary",
            "exitCode": 0,
            "output": { "SummaryMap": { "AccountMFAEnabled": 0 } }
          }
        ]
      }
    ]
  },
  {
    "controlId": "CR-AWS-IAM-002",
    "cases": [
      {
        "name": "passes when no root access keys",
        "expected": "pass",
        "records": [
          {
            "collectorId": "aws.iam.get_account_summary",
            "exitCode": 0,
            "output": { "SummaryMap": { "AccountAccessKeysPresent": 0 } }
          }
        ]
      },
      {
        "name": "fails when root access key exists",
        "expected": "fail",
        "records": [
          {
            "collectorId": "aws.iam.get_account_summary",
            "exitCode": 0,
            "output": { "SummaryMap": { "AccountAccessKeysPresent": 1 } }
          }
        ]
      }
    ]
  },
  {
    "controlId": "CR-AWS-IAM-003",
    "cases": [
      {
        "name": "passes at length 14",
        "expected": "pass",
        "records": [
          {
            "collectorId": "aws.iam.get_account_password_policy",
            "exitCode": 0,
            "output": { "PasswordPolicy": { "MinimumPasswordLength": 14 } }
          }
        ]
      },
      {
        "name": "fails at length 8",
        "expected": "fail",
        "records": [
          {
            "collectorId": "aws.iam.get_account_password_policy",
            "exitCode": 0,
            "output": { "PasswordPolicy": { "MinimumPasswordLength": 8 } }
          }
        ]
      },
      {
        "name": "fails when no policy exists (NoSuchEntity)",
        "expected": "fail",
        "records": [
          {
            "collectorId": "aws.iam.get_account_password_policy",
            "exitCode": 254,
            "output": null,
            "errorText": "An error occurred (NoSuchEntity) when calling the GetAccountPasswordPolicy operation: The Password Policy with domain name 123456789012 cannot be found."
          }
        ]
      }
    ]
  },
