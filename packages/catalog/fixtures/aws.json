  {
    "controlId": "CR-AWS-S3-001",
    "cases": [
      {
        "name": "passes with all four settings",
        "expected": "pass",
        "records": [
          {
            "collectorId": "aws.s3.get_public_access_block",
            "resourceKey": "good-bucket",
            "exitCode": 0,
            "output": {
              "PublicAccessBlockConfiguration": {
                "BlockPublicAcls": true,
                "IgnorePublicAcls": true,
                "BlockPublicPolicy": true,
                "RestrictPublicBuckets": true
              }
            }
          }
        ]
      },
      {
        "name": "fails with one setting off",
        "expected": "fail",
        "records": [
          {
            "collectorId": "aws.s3.get_public_access_block",
            "resourceKey": "partial-bucket",
            "exitCode": 0,
            "output": {
              "PublicAccessBlockConfiguration": {
                "BlockPublicAcls": true,
                "IgnorePublicAcls": true,
                "BlockPublicPolicy": true,
                "RestrictPublicBuckets": false
              }
            }
          }
        ]
      },
      {
        "name": "fails when configuration absent",
        "expected": "fail",
        "records": [
          {
            "collectorId": "aws.s3.get_public_access_block",
            "resourceKey": "bare-bucket",
            "exitCode": 254,
            "output": null,
            "errorText": "An error occurred (NoSuchPublicAccessBlockConfiguration) when calling the GetPublicAccessBlock operation"
          }
        ]
      },
      {
        "name": "errors on access denied",
        "expected": "error",
        "records": [
          {
            "collectorId": "aws.s3.get_public_access_block",
            "resourceKey": "denied-bucket",
            "exitCode": 254,
            "output": null,
            "errorText": "An error occurred (AccessDenied) when calling the GetPublicAccessBlock operation"
          }
        ]
      }
    ]
  },
