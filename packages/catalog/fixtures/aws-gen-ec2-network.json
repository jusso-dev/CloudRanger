[
  {
    "controlId": "CR-AWS-EC2-021",
    "cases": [
      {
        "name": "non-default vpc",
        "expected": "pass",
        "records": [
          {
            "collectorId": "aws.ec2.describe_vpcs",
            "region": "us-east-1",
            "exitCode": 0,
            "output": {
              "Vpcs": [
                {
                  "VpcId": "vpc-aaa",
                  "IsDefault": false
                }
              ]
            }
          }
        ]
      },
      {
        "name": "default vpc present",
        "expected": "fail",
        "records": [
          {
            "collectorId": "aws.ec2.describe_vpcs",
            "region": "us-east-1",
            "exitCode": 0,
            "output": {
              "Vpcs": [
                {
                  "VpcId": "vpc-def",
                  "IsDefault": true
                }
              ]
            }
          }
        ]
      }
    ]
  },
