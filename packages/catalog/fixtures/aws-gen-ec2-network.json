            "region": "us-east-1",
            "exitCode": 0,
            "output": {
              "NetworkAcls": [
                {
                  "NetworkAclId": "acl-1",
                  "Entries": [
                    {
                      "RuleNumber": 100,
                      "Protocol": "6",
                      "RuleAction": "allow",
                      "Egress": false,
                      "CidrBlock": "10.0.0.0/16",
