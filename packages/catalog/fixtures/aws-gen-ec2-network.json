                {
                  "NetworkAclId": "acl-2",
                  "Entries": [
                    {
                      "RuleNumber": 100,
                      "Protocol": "6",
                      "RuleAction": "allow",
                      "Egress": false,
                      "CidrBlock": "0.0.0.0/0",
                      "PortRange": {
                        "From": 22,
                        "To": 22
                      }
                    }
                  ]
                }
              ]
            }
          }
        ]
      }
    ]
  },
