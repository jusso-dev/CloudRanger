[
  {
    "controlId": "CR-AWS-ECS-001",
    "cases": [
      {
        "name": "no privileged containers",
        "expected": "pass",
        "records": [
          {
            "collectorId": "aws.ecs.describe_task_definition",
            "region": "us-east-1",
            "resourceKey": "arn:aws:ecs:us-east-1:111122223333:task-definition/web:3",
            "exitCode": 0,
            "output": {
              "taskDefinition": {
                "taskDefinitionArn": "arn:aws:ecs:us-east-1:111122223333:task-definition/web:3",
                "family": "web",
                "networkMode": "awsvpc",
                "containerDefinitions": [
                  {
                    "name": "app",
                    "image": "nginx:latest",
                    "privileged": false
                  },
                  {
                    "name": "sidecar",
                    "image": "envoy:latest"
                  }
                ]
              }
            }
          }
        ]
      },
      {
        "name": "privileged container present",
        "expected": "fail",
        "records": [
          {
            "collectorId": "aws.ecs.describe_task_definition",
            "region": "us-east-1",
            "resourceKey": "arn:aws:ecs:us-east-1:111122223333:task-definition/priv:1",
            "exitCode": 0,
            "output": {
              "taskDefinition": {
                "taskDefinitionArn": "arn:aws:ecs:us-east-1:111122223333:task-definition/priv:1",
                "family": "priv",
                "networkMode": "bridge",
                "containerDefinitions": [
                  {
                    "name": "app",
                    "image": "app:latest",
                    "privileged": true
                  }
                ]
              }
            }
          }
        ]
      }
    ]
  },
  {
    "controlId": "CR-AWS-ECS-002",
    "cases": [
      {
        "name": "all containers log",
        "expected": "pass",
        "records": [
          {
            "collectorId": "aws.ecs.describe_task_definition",
            "region": "us-east-1",
            "resourceKey": "arn:aws:ecs:us-east-1:111122223333:task-definition/web:3",
            "exitCode": 0,
            "output": {
              "taskDefinition": {
                "taskDefinitionArn": "arn:aws:ecs:us-east-1:111122223333:task-definition/web:3",
                "family": "web",
                "networkMode": "awsvpc",
                "containerDefinitions": [
                  {
                    "name": "app",
                    "image": "nginx:latest",
                    "logConfiguration": {
                      "logDriver": "awslogs",
                      "options": {
                        "awslogs-group": "/ecs/web",
                        "awslogs-region": "us-east-1",
                        "awslogs-stream-prefix": "app"
                      }
                    }
                  }
                ]
              }
            }
          }
        ]
      },
      {
        "name": "container missing log configuration",
        "expected": "fail",
        "records": [
          {
            "collectorId": "aws.ecs.describe_task_definition",
            "region": "us-east-1",
            "resourceKey": "arn:aws:ecs:us-east-1:111122223333:task-definition/nolog:1",
            "exitCode": 0,
            "output": {
              "taskDefinition": {
                "taskDefinitionArn": "arn:aws:ecs:us-east-1:111122223333:task-definition/nolog:1",
                "family": "nolog",
                "networkMode": "awsvpc",
                "containerDefinitions": [
                  {
                    "name": "app",
                    "image": "nginx:latest",
                    "logConfiguration": {
                      "logDriver": "awslogs"
                    }
                  },
                  {
                    "name": "sidecar",
                    "image": "envoy:latest"
                  }
                ]
              }
            }
          }
        ]
      }
    ]
  },
