            "exitCode": 0,
            "output": {
              "taskDefinition": {
                "taskDefinitionArn": "arn:aws:ecs:us-east-1:111122223333:task-definition/app:4",
                "family": "app",
                "networkMode": "awsvpc",
                "containerDefinitions": [
                  {
                    "name": "web",
