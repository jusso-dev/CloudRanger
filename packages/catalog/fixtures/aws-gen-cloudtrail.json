  {
    "controlId": "CR-AWS-CLOUDTRAIL-012",
    "cases": [
      {
        "name": "pass no public acl grants",
        "expected": "pass",
        "records": [
          {
            "collectorId": "aws.s3.get_bucket_acl",
            "resourceKey": "log-bucket-private",
            "exitCode": 0,
            "output": {
              "Owner": {
                "DisplayName": "acct",
                "ID": "abc123ownerid"
              },
              "Grants": [
                {
                  "Grantee": {
                    "Type": "CanonicalUser",
                    "DisplayName": "acct",
                    "ID": "abc123ownerid"
                  },
                  "Permission": "FULL_CONTROL"
                }
              ]
            }
          }
        ]
      },
      {
        "name": "fail allusers grant",
        "expected": "fail",
        "records": [
          {
            "collectorId": "aws.s3.get_bucket_acl",
            "resourceKey": "log-bucket-public",
            "exitCode": 0,
            "output": {
              "Owner": {
                "DisplayName": "acct",
                "ID": "abc123ownerid"
              },
              "Grants": [
                {
                  "Grantee": {
                    "Type": "CanonicalUser",
                    "DisplayName": "acct",
                    "ID": "abc123ownerid"
                  },
                  "Permission": "FULL_CONTROL"
                },
                {
                  "Grantee": {
                    "Type": "Group",
                    "URI": "http://acs.amazonaws.com/groups/global/AllUsers"
                  },
                  "Permission": "READ"
                }
              ]
            }
          }
        ]
      },
      {
        "name": "error access denied on bucket acl",
        "expected": "error",
        "records": [
          {
            "collectorId": "aws.s3.get_bucket_acl",
            "resourceKey": "cross-account-bucket",
            "exitCode": 254,
            "output": null,
            "errorText": "An error occurred (AccessDenied) when calling the GetBucketAcl operation: Access Denied"
          }
        ]
      }
    ]
  },
