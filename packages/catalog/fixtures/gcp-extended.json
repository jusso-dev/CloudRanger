[
  {
    "controlId": "CR-GCP-GKE-001",
    "cases": [
      {
        "name": "passes private nodes",
        "expected": "pass",
        "records": [
          {
            "collectorId": "gcp.container.clusters_list",
            "exitCode": 0,
            "output": [
              { "name": "prod-cluster", "privateClusterConfig": { "enablePrivateNodes": true } }
            ]
          }
        ]
      },
      {
        "name": "fails public nodes",
        "expected": "fail",
        "records": [
          {
            "collectorId": "gcp.container.clusters_list",
            "exitCode": 0,
            "output": [{ "name": "legacy-cluster" }]
          }
        ]
      }
    ]
  },
  {
    "controlId": "CR-GCP-GKE-002",
    "cases": [
      {
        "name": "passes with network policy addon",
        "expected": "pass",
        "records": [
          {
            "collectorId": "gcp.container.clusters_list",
            "exitCode": 0,
            "output": [{ "name": "np-cluster", "networkPolicy": { "enabled": true } }]
          }
        ]
      },
      {
        "name": "passes with Dataplane V2",
        "expected": "pass",
        "records": [
          {
            "collectorId": "gcp.container.clusters_list",
            "exitCode": 0,
            "output": [
              {
                "name": "dpv2-cluster",
                "networkConfig": { "datapathProvider": "ADVANCED_DATAPATH" }
              }
            ]
          }
        ]
      },
      {
        "name": "fails without policy enforcement",
        "expected": "fail",
        "records": [
          {
            "collectorId": "gcp.container.clusters_list",
            "exitCode": 0,
            "output": [{ "name": "flat-cluster", "networkPolicy": { "enabled": false } }]
          }
        ]
      },
      {
        "name": "not applicable for autopilot",
        "expected": "not_applicable",
        "records": [
          {
            "collectorId": "gcp.container.clusters_list",
            "exitCode": 0,
            "output": [{ "name": "auto-cluster", "autopilot": { "enabled": true } }]
          }
        ]
      }
    ]
  },
