  {
    "controlId": "CR-GCP-IAM-003",
    "cases": [
      {
        "name": "fails when SA has editor",
        "expected": "fail",
        "records": [
          {
            "collectorId": "gcp.project.iam_policy",
            "exitCode": 0,
            "output": {
              "bindings": [
                {
                  "role": "roles/editor",
                  "members": [
                    "serviceAccount:app@proj.iam.gserviceaccount.com",
                    "user:dev@example.com"
                  ]
                }
              ]
            }
          }
        ]
      },
      {
        "name": "passes when SAs have scoped roles",
        "expected": "pass",
        "records": [
          {
            "collectorId": "gcp.project.iam_policy",
            "exitCode": 0,
            "output": {
              "bindings": [
                { "role": "roles/owner", "members": ["user:admin@example.com"] },
                {
                  "role": "roles/storage.objectAdmin",
                  "members": ["serviceAccount:app@proj.iam.gserviceaccount.com"]
                }
              ]
            }
          }
        ]
      }
    ]
  }
