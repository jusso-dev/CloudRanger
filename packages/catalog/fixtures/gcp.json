  {
    "controlId": "CR-GCP-IAM-001",
    "cases": [
      {
        "name": "fails with stale user-managed key",
        "expected": "fail",
        "records": [
          {
            "collectorId": "gcp.iam.service_account_keys_list",
            "resourceKey": "app@proj.iam.gserviceaccount.com",
            "exitCode": 0,
            "output": [
              {
                "name": "projects/proj/serviceAccounts/app/keys/1",
                "keyType": "USER_MANAGED",
                "validAfterTime": "2025-01-01T00:00:00Z"
              }
            ]
          }
        ]
      },
      {
        "name": "passes with only system-managed keys",
        "expected": "pass",
        "records": [
          {
            "collectorId": "gcp.iam.service_account_keys_list",
            "resourceKey": "clean@proj.iam.gserviceaccount.com",
            "exitCode": 0,
            "output": [
              {
                "name": "projects/proj/serviceAccounts/clean/keys/2",
                "keyType": "SYSTEM_MANAGED",
                "validAfterTime": "2024-01-01T00:00:00Z"
              }
            ]
          }
        ]
      },
      {
        "name": "passes with fresh user-managed key",
        "expected": "pass",
        "records": [
          {
            "collectorId": "gcp.iam.service_account_keys_list",
            "resourceKey": "fresh@proj.iam.gserviceaccount.com",
            "exitCode": 0,
            "output": [
              {
                "name": "projects/proj/serviceAccounts/fresh/keys/3",
                "keyType": "USER_MANAGED",
                "validAfterTime": "2025-12-15T00:00:00Z"
              }
            ]
          }
        ]
      }
    ]
  },
