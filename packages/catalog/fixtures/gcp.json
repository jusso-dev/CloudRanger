  {
    "controlId": "CR-GCP-FIREWALL-001",
    "cases": [
      {
        "name": "fails with SSH open to world",
        "expected": "fail",
        "records": [
          {
            "collectorId": "gcp.compute.firewall_rules_list",
            "exitCode": 0,
            "output": [
              {
                "name": "allow-ssh-all",
                "direction": "INGRESS",
                "disabled": false,
                "sourceRanges": ["0.0.0.0/0"],
                "allowed": [{ "IPProtocol": "tcp", "ports": ["22"] }]
              }
            ]
          }
        ]
      },
      {
        "name": "fails with all-protocol rule open to world",
        "expected": "fail",
        "records": [
          {
            "collectorId": "gcp.compute.firewall_rules_list",
            "exitCode": 0,
            "output": [
              {
                "name": "allow-everything",
                "direction": "INGRESS",
                "disabled": false,
                "sourceRanges": ["0.0.0.0/0"],
                "allowed": [{ "IPProtocol": "all" }]
              }
            ]
          }
        ]
      },
      {
        "name": "passes with restricted source",
        "expected": "pass",
        "records": [
          {
            "collectorId": "gcp.compute.firewall_rules_list",
            "exitCode": 0,
            "output": [
              {
                "name": "allow-ssh-office",
                "direction": "INGRESS",
                "disabled": false,
                "sourceRanges": ["203.0.113.0/24"],
                "allowed": [{ "IPProtocol": "tcp", "ports": ["22"] }]
              }
            ]
          }
        ]
      },
      {
        "name": "not applicable when rule disabled",
        "expected": "not_applicable",
        "records": [
          {
            "collectorId": "gcp.compute.firewall_rules_list",
            "exitCode": 0,
            "output": [
              {
                "name": "allow-ssh-disabled",
                "direction": "INGRESS",
                "disabled": true,
                "sourceRanges": ["0.0.0.0/0"],
                "allowed": [{ "IPProtocol": "tcp", "ports": ["22"] }]
              }
            ]
          }
        ]
      }
    ]
  },
  {
    "controlId": "CR-GCP-FIREWALL-002",
    "cases": [
      {
        "name": "fails with RDP open in a range",
        "expected": "fail",
        "records": [
          {
            "collectorId": "gcp.compute.firewall_rules_list",
            "exitCode": 0,
            "output": [
              {
                "name": "allow-win-mgmt",
                "direction": "INGRESS",
                "disabled": false,
                "sourceRanges": ["0.0.0.0/0"],
                "allowed": [{ "IPProtocol": "tcp", "ports": ["3300-3400"] }]
              }
            ]
          }
        ]
      },
      {
        "name": "passes with unrelated ports",
        "expected": "pass",
        "records": [
          {
            "collectorId": "gcp.compute.firewall_rules_list",
            "exitCode": 0,
            "output": [
              {
                "name": "allow-web",
                "direction": "INGRESS",
                "disabled": false,
                "sourceRanges": ["0.0.0.0/0"],
                "allowed": [{ "IPProtocol": "tcp", "ports": ["80", "443"] }]
              }
            ]
          }
        ]
      }
    ]
  },
