[
  {
    "controlId": "CR-GCP-STORAGE-001",
    "cases": [
      {
        "name": "fails with allUsers binding",
        "expected": "fail",
        "records": [
          {
            "collectorId": "gcp.storage.bucket_iam_policy",
            "resourceKey": "public-bucket",
            "exitCode": 0,
            "output": {
              "bindings": [{ "role": "roles/storage.objectViewer", "members": ["allUsers"] }]
            }
          }
        ]
      },
      {
        "name": "fails with allAuthenticatedUsers binding",
        "expected": "fail",
        "records": [
          {
            "collectorId": "gcp.storage.bucket_iam_policy",
            "resourceKey": "authed-bucket",
            "exitCode": 0,
            "output": {
              "bindings": [
                {
                  "role": "roles/storage.objectViewer",
                  "members": ["allAuthenticatedUsers", "user:alice@example.com"]
                }
              ]
            }
          }
        ]
      },
      {
        "name": "passes with scoped members only",
        "expected": "pass",
        "records": [
          {
            "collectorId": "gcp.storage.bucket_iam_policy",
            "resourceKey": "private-bucket",
            "exitCode": 0,
            "output": {
              "bindings": [
                {
                  "role": "roles/storage.admin",
                  "members": ["serviceAccount:app@proj.iam.gserviceaccount.com"]
                }
              ]
            }
          }
        ]
      }
    ]
  },
  {
