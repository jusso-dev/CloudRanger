  {
    "controlId": "CR-AWS-ECR-004",
    "cases": [
      {
        "name": "lifecycle policy present passes",
        "expected": "pass",
        "records": [
          {
            "collectorId": "aws.ecr.get_lifecycle_policy",
            "region": "us-east-1",
            "resourceKey": "app",
            "exitCode": 0,
            "output": {
              "registryId": "111122223333",
              "repositoryName": "app",
              "lifecyclePolicyText": "{\"rules\":[{\"rulePriority\":1,\"description\":\"expire untagged\",\"selection\":{\"tagStatus\":\"untagged\",\"countType\":\"sinceImagePushed\",\"countUnit\":\"days\",\"countNumber\":14},\"action\":{\"type\":\"expire\"}}]}"
            }
          }
        ]
      },
      {
        "name": "no lifecycle policy fails via onError",
        "expected": "fail",
        "records": [
          {
            "collectorId": "aws.ecr.get_lifecycle_policy",
            "region": "us-east-1",
            "resourceKey": "legacy",
            "exitCode": 254,
            "output": null,
            "errorText": "An error occurred (LifecyclePolicyNotFoundException) when calling the GetLifecyclePolicy operation: Lifecycle policy does not exist for the repository with name 'legacy' in the registry with id '111122223333'"
          }
        ]
      },
      {
        "name": "access denied errors",
        "expected": "error",
        "records": [
          {
            "collectorId": "aws.ecr.get_lifecycle_policy",
            "region": "us-east-1",
            "resourceKey": "restricted",
            "exitCode": 254,
            "output": null,
            "errorText": "An error occurred (AccessDeniedException) when calling the GetLifecyclePolicy operation: User is not authorized to perform ecr:GetLifecyclePolicy"
          }
        ]
      }
    ]
  },
