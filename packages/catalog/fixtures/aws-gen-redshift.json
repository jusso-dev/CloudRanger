  {
    "controlId": "CR-AWS-REDSHIFT-008",
    "cases": [
      {
        "name": "fails when logging disabled",
        "expected": "fail",
        "records": [
          {
            "collectorId": "aws.redshift.describe_logging_status",
            "region": "us-east-1",
            "resourceKey": "nolog-dw",
            "exitCode": 0,
            "output": {
              "LoggingEnabled": false
            }
          }
        ]
      },
      {
        "name": "passes when logging enabled to s3",
        "expected": "pass",
        "records": [
          {
            "collectorId": "aws.redshift.describe_logging_status",
            "region": "us-east-1",
            "resourceKey": "log-dw",
            "exitCode": 0,
            "output": {
              "LoggingEnabled": true,
              "BucketName": "my-redshift-audit-logs",
              "S3KeyPrefix": "redshift/",
              "LogDestinationType": "s3",
              "LastSuccessfulDeliveryTime": "2026-07-10T02:15:00Z"
            }
          }
        ]
      },
      {
        "name": "not applicable when cluster deleted",
        "expected": "not_applicable",
        "records": [
          {
            "collectorId": "aws.redshift.describe_logging_status",
            "region": "us-east-1",
            "resourceKey": "gone-dw",
            "exitCode": 254,
            "output": null,
            "errorText": "An error occurred (ClusterNotFound) when calling the DescribeLoggingStatus operation: Cluster gone-dw not found."
          }
        ]
      }
    ]
  },
  {
    "controlId": "CR-AWS-REDSHIFT-009",
    "cases": [
      {
        "name": "fails when require_ssl false",
        "expected": "fail",
        "records": [
          {
            "collectorId": "aws.redshift.describe_cluster_parameters",
            "region": "us-east-1",
            "resourceKey": "default.redshift-1.0",
            "exitCode": 0,
            "output": {
              "Parameters": [
                {
                  "ParameterName": "auto_analyze",
                  "ParameterValue": "true",
                  "DataType": "boolean",
                  "Source": "engine-default"
                },
                {
                  "ParameterName": "require_ssl",
                  "ParameterValue": "false",
                  "DataType": "boolean",
                  "Source": "engine-default"
                }
              ]
            }
          }
        ]
      },
      {
        "name": "passes when require_ssl true",
        "expected": "pass",
        "records": [
          {
            "collectorId": "aws.redshift.describe_cluster_parameters",
            "region": "us-east-1",
            "resourceKey": "ssl-pg",
            "exitCode": 0,
            "output": {
              "Parameters": [
                {
                  "ParameterName": "require_ssl",
                  "ParameterValue": "true",
                  "DataType": "boolean",
                  "Source": "user"
                },
                {
                  "ParameterName": "enable_user_activity_logging",
                  "ParameterValue": "true",
                  "DataType": "boolean",
                  "Source": "user"
                }
              ]
            }
          }
        ]
      },
      {
        "name": "not applicable when parameter group missing",
        "expected": "not_applicable",
        "records": [
          {
            "collectorId": "aws.redshift.describe_cluster_parameters",
            "region": "us-east-1",
            "resourceKey": "missing-pg",
            "exitCode": 254,
            "output": null,
            "errorText": "An error occurred (ClusterParameterGroupNotFound) when calling the DescribeClusterParameters operation: ParameterGroup missing-pg not found."
          }
        ]
      }
    ]
  }
