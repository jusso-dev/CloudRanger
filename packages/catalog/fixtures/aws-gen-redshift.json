[
  {
    "controlId": "CR-AWS-REDSHIFT-001",
    "cases": [
      {
        "name": "fails when publicly accessible",
        "expected": "fail",
        "records": [
          {
            "collectorId": "aws.redshift.describe_clusters",
            "region": "us-east-1",
            "exitCode": 0,
            "output": {
              "Clusters": [
                {
                  "ClusterIdentifier": "public-dw",
                  "NodeType": "ra3.xlplus",
                  "ClusterStatus": "available",
                  "MasterUsername": "adminuser",
                  "PubliclyAccessible": true,
                  "Encrypted": true,
                  "EnhancedVpcRouting": true,
                  "AutomatedSnapshotRetentionPeriod": 7,
                  "AllowVersionUpgrade": true
                }
              ]
            }
          }
        ]
      },
      {
        "name": "passes when private",
        "expected": "pass",
        "records": [
          {
            "collectorId": "aws.redshift.describe_clusters",
            "region": "us-east-1",
            "exitCode": 0,
            "output": {
              "Clusters": [
                {
                  "ClusterIdentifier": "private-dw",
                  "NodeType": "ra3.xlplus",
                  "ClusterStatus": "available",
                  "MasterUsername": "adminuser",
                  "PubliclyAccessible": false,
                  "Encrypted": true,
                  "EnhancedVpcRouting": true,
                  "AutomatedSnapshotRetentionPeriod": 7,
                  "AllowVersionUpgrade": true
                }
              ]
            }
          }
        ]
      }
    ]
  },
