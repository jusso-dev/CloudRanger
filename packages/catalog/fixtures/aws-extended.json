  {
    "controlId": "CR-AWS-S3-004",
    "cases": [
      {
        "name": "passes with all account-level settings",
        "expected": "pass",
        "records": [
          {
            "collectorId": "aws.s3control.get_account_public_access_block",
            "exitCode": 0,
            "output": {
              "PublicAccessBlockConfiguration": {
                "BlockPublicAcls": true,
                "IgnorePublicAcls": true,
                "BlockPublicPolicy": true,
                "RestrictPublicBuckets": true
              }
            }
          }
        ]
      },
      {
        "name": "fails when not configured",
        "expected": "fail",
        "records": [
          {
            "collectorId": "aws.s3control.get_account_public_access_block",
            "exitCode": 254,
            "output": null,
            "errorText": "An error occurred (NoSuchPublicAccessBlockConfiguration) when calling the GetPublicAccessBlock operation"
          }
        ]
      }
    ]
  },
