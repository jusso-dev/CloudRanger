[
  {
    "controlId": "CR-AWS-EC2-005",
    "cases": [
      {
        "name": "passes when default SG has no rules",
        "expected": "pass",
        "records": [
          {
            "collectorId": "aws.ec2.describe_security_groups",
            "region": "ap-southeast-2",
            "exitCode": 0,
            "output": {
              "SecurityGroups": [
                {
                  "GroupId": "sg-def",
                  "GroupName": "default",
                  "IpPermissions": [],
                  "IpPermissionsEgress": []
                }
              ]
            }
          }
        ]
      },
      {
        "name": "fails when default SG has rules",
        "expected": "fail",
        "records": [
          {
            "collectorId": "aws.ec2.describe_security_groups",
            "region": "ap-southeast-2",
            "exitCode": 0,
            "output": {
              "SecurityGroups": [
                {
                  "GroupId": "sg-def2",
                  "GroupName": "default",
                  "IpPermissions": [
                    { "IpProtocol": "-1", "UserIdGroupPairs": [{ "GroupId": "sg-def2" }] }
                  ],
                  "IpPermissionsEgress": [
                    { "IpProtocol": "-1", "IpRanges": [{ "CidrIp": "0.0.0.0/0" }] }
                  ]
                }
              ]
            }
          }
        ]
      },
      {
        "name": "not applicable to non-default groups",
        "expected": "not_applicable",
        "records": [
          {
            "collectorId": "aws.ec2.describe_security_groups",
            "region": "ap-southeast-2",
            "exitCode": 0,
            "output": {
              "SecurityGroups": [
                {
                  "GroupId": "sg-app",
                  "GroupName": "app-servers",
                  "IpPermissions": [
                    {
                      "IpProtocol": "tcp",
                      "FromPort": 443,
                      "ToPort": 443,
                      "IpRanges": [{ "CidrIp": "0.0.0.0/0" }]
                    }
                  ],
                  "IpPermissionsEgress": []
                }
              ]
            }
          }
        ]
      }
    ]
  },
