[
  {
    "controlId": "CR-GCP-FIREWALL-100",
    "cases": [
      {
        "name": "fails open ssh from internet",
        "expected": "fail",
        "resourceId": "allow-ssh-world",
        "records": [
          {
            "collectorId": "gcp.compute.firewall_rules_list",
            "exitCode": 0,
            "output": [
              {
                "name": "allow-ssh-world",
                "network": "https://www.googleapis.com/compute/v1/projects/p/global/networks/default",
                "direction": "INGRESS",
                "priority": 1000,
                "disabled": false,
                "sourceRanges": ["0.0.0.0/0"],
                "allowed": [
                  {
                    "IPProtocol": "tcp",
                    "ports": ["22"]
                  }
                ],
                "logConfig": {
                  "enable": false
                }
              }
            ]
          }
        ]
      },
      {
        "name": "passes restricted ssh",
        "expected": "pass",
