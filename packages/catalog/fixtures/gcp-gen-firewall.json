            "output": [
              {
                "name": "allow-ssh-corp",
                "direction": "INGRESS",
                "priority": 1000,
                "disabled": false,
                "sourceRanges": ["10.0.0.0/8"],
                "allowed": [
                  {
                    "IPProtocol": "tcp",
                    "ports": ["22"]
                  }
                ],
                "logConfig": {
                  "enable": true
                }
              }
            ]
          }
        ]
      },
