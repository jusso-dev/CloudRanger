              "Policy": "{\"Version\":\"2012-10-17\",\"Id\":\"default\",\"Statement\":[{\"Sid\":\"public\",\"Effect\":\"Allow\",\"Principal\":\"*\",\"Action\":\"lambda:InvokeFunction\",\"Resource\":\"arn:aws:lambda:us-east-1:111122223333:function:public-fn\"}]}",
              "RevisionId": "abc-123"
            }
          }
        ]
      },
      {
        "name": "wildcard principal scoped by condition passes",
        "expected": "pass",
        "records": [
          {
            "collectorId": "aws.lambda.get_policy",
            "region": "us-east-1",
            "resourceKey": "scoped-fn",
            "exitCode": 0,
            "output": {
              "Policy": "{\"Version\":\"2012-10-17\",\"Id\":\"default\",\"Statement\":[{\"Sid\":\"s3\",\"Effect\":\"Allow\",\"Principal\":{\"Service\":\"s3.amazonaws.com\"},\"Action\":\"lambda:InvokeFunction\",\"Resource\":\"arn:aws:lambda:us-east-1:111122223333:function:scoped-fn\",\"Condition\":{\"StringEquals\":{\"AWS:SourceAccount\":\"111122223333\"}}}]}",
              "RevisionId": "def-456"
            }
          }
        ]
      },
      {
        "name": "no policy attached passes",
        "expected": "pass",
        "records": [
          {
            "collectorId": "aws.lambda.get_policy",
            "region": "us-east-1",
            "resourceKey": "private-fn",
            "exitCode": 254,
