[
  {
    "controlId": "CR-AWS-ACM-001",
    "cases": [
      {
        "name": "transparency logging enabled passes",
        "expected": "pass",
        "records": [
          {
            "collectorId": "aws.acm.describe_certificate",
            "region": "us-east-1",
            "resourceKey": "arn:aws:acm:us-east-1:111122223333:certificate/aaaaaaaa-1111-2222-3333-444444444444",
            "exitCode": 0,
            "output": {
              "Certificate": {
                "CertificateArn": "arn:aws:acm:us-east-1:111122223333:certificate/aaaaaaaa-1111-2222-3333-444444444444",
                "DomainName": "www.example.com",
                "SubjectAlternativeNames": ["www.example.com"],
                "Status": "ISSUED",
                "Type": "AMAZON_ISSUED",
                "KeyAlgorithm": "RSA-2048",
                "RenewalEligibility": "ELIGIBLE",
                "Options": {
                  "CertificateTransparencyLoggingPreference": "ENABLED"
                }
              }
            }
          }
        ]
      },
