                "SubjectAlternativeNames": ["api.example.com"],
                "Status": "ISSUED",
                "Type": "AMAZON_ISSUED",
                "KeyAlgorithm": "RSA-2048",
                "RenewalEligibility": "ELIGIBLE",
                "Options": {
                  "CertificateTransparencyLoggingPreference": "DISABLED"
                }
              }
            }
          }
        ]
      },
      {
