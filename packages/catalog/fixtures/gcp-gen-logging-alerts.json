[
  {
    "controlId": "CR-GCP-LOGGING-113",
    "cases": [
      {
        "name": "passes when audit metric is alerted",
        "expected": "pass",
        "records": [
          {
            "collectorId": "gcp.logging.metrics_list",
            "exitCode": 0,
            "output": [
              {
                "name": "audit-change",
                "filter": "protoPayload.methodName=\"SetIamPolicy\" AND protoPayload.serviceData.policyDelta.auditConfigDeltas:*"
              }
            ]
          },
          {
            "collectorId": "gcp.monitoring.alert_policies_list",
            "exitCode": 0,
            "output": [
              {
                "conditions": [
                  {
                    "conditionThreshold": {
                      "filter": "metric.type=\"logging.googleapis.com/user/audit-change\""
                    }
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "name": "fails without alert",
        "expected": "fail",
        "records": [
          {
            "collectorId": "gcp.logging.metrics_list",
            "exitCode": 0,
            "output": [
              {
                "name": "audit-change",
                "filter": "protoPayload.methodName=\"SetIamPolicy\" AND protoPayload.serviceData.policyDelta.auditConfigDeltas:*"
              }
            ]
          },
          { "collectorId": "gcp.monitoring.alert_policies_list", "exitCode": 0, "output": [] }
        ]
      }
    ]
  },
