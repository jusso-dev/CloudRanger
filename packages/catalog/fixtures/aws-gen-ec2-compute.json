    "cases": [
      {
        "name": "private snapshot",
        "expected": "pass",
        "records": [
          {
            "collectorId": "aws.ec2.describe_snapshot_attribute_cvp",
            "region": "us-east-1",
            "resourceKey": "snap-01",
            "exitCode": 0,
            "output": {
              "SnapshotId": "snap-01",
              "CreateVolumePermissions": []
            }
          }
        ]
      },
      {
        "name": "public snapshot",
        "expected": "fail",
        "records": [
          {
            "collectorId": "aws.ec2.describe_snapshot_attribute_cvp",
            "region": "us-east-1",
            "resourceKey": "snap-02",
            "exitCode": 0,
            "output": {
              "SnapshotId": "snap-02",
              "CreateVolumePermissions": [
                {
                  "Group": "all"
                }
              ]
            }
          }
        ]
      },
      {
        "name": "snapshot gone",
        "expected": "not_applicable",
        "records": [
          {
            "collectorId": "aws.ec2.describe_snapshot_attribute_cvp",
            "region": "us-east-1",
            "resourceKey": "snap-03",
            "exitCode": 254,
            "output": null,
            "errorText": "An error occurred (InvalidSnapshot.NotFound) when calling the DescribeSnapshotAttribute operation: The snapshot 'snap-03' does not exist."
          }
        ]
      }
    ]
