[
  {
    "controlId": "CR-AWS-RDS-010",
    "cases": [
      {
        "name": "fail public snapshot",
        "expected": "fail",
        "records": [
          {
            "collectorId": "aws.rds.describe_db_snapshot_attributes",
            "region": "us-east-1",
            "resourceKey": "mydbsnapshot",
            "exitCode": 0,
            "output": {
              "DBSnapshotAttributesResult": {
                "DBSnapshotIdentifier": "mydbsnapshot",
                "DBSnapshotAttributes": [
                  {
                    "AttributeName": "restore",
                    "AttributeValues": ["all"]
                  }
                ]
              }
            }
          }
        ]
      },
      {
        "name": "pass shared to specific accounts",
        "expected": "pass",
        "records": [
          {
            "collectorId": "aws.rds.describe_db_snapshot_attributes",
            "region": "us-east-1",
            "resourceKey": "privsnap",
            "exitCode": 0,
            "output": {
              "DBSnapshotAttributesResult": {
                "DBSnapshotIdentifier": "privsnap",
                "DBSnapshotAttributes": [
                  {
                    "AttributeName": "restore",
                    "AttributeValues": ["123456789012"]
                  }
                ]
              }
            }
          }
        ]
      },
      {
        "name": "pass no restore sharing",
        "expected": "pass",
        "records": [
          {
            "collectorId": "aws.rds.describe_db_snapshot_attributes",
            "region": "us-east-1",
            "resourceKey": "privsnap2",
            "exitCode": 0,
            "output": {
              "DBSnapshotAttributesResult": {
                "DBSnapshotIdentifier": "privsnap2",
                "DBSnapshotAttributes": [
                  {
                    "AttributeName": "restore",
                    "AttributeValues": []
                  }
                ]
              }
            }
          }
        ]
      },
      {
        "name": "na automated snapshot error",
        "expected": "not_applicable",
        "records": [
          {
            "collectorId": "aws.rds.describe_db_snapshot_attributes",
            "region": "us-east-1",
            "resourceKey": "rds:auto-2024-01-01",
            "exitCode": 254,
            "output": null,
            "errorText": "An error occurred (InvalidDBSnapshotState) when calling the DescribeDBSnapshotAttributes operation: Cannot get attributes for automated snapshot."
          }
        ]
      }
    ]
  },
