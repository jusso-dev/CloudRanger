[
  {
    "controlId": "CR-AWS-CLOUDFRONT-001",
    "cases": [
      {
        "name": "fails allow-all default behavior",
        "expected": "fail",
        "records": [
          {
            "collectorId": "aws.cloudfront.list_distributions",
            "exitCode": 0,
            "output": {
              "DistributionList": {
                "Quantity": 1,
                "Items": [
                  {
                    "Id": "E1AAA",
                    "ARN": "arn:aws:cloudfront::111122223333:distribution/E1AAA",
                    "DomainName": "d1.cloudfront.net",
                    "DefaultCacheBehavior": {
                      "ViewerProtocolPolicy": "allow-all"
                    },
                    "CacheBehaviors": {
                      "Quantity": 0
                    },
                    "Origins": {
                      "Quantity": 1,
                      "Items": []
                    },
                    "ViewerCertificate": {
                      "MinimumProtocolVersion": "TLSv1.2_2021"
                    },
                    "Restrictions": {
                      "GeoRestriction": {
                        "RestrictionType": "none",
                        "Quantity": 0
                      }
                    },
                    "WebACLId": ""
                  }
                ]
              }
            }
          }
        ]
      },
      {
        "name": "passes redirect-to-https",
        "expected": "pass",
        "records": [
          {
            "collectorId": "aws.cloudfront.list_distributions",
            "exitCode": 0,
            "output": {
              "DistributionList": {
                "Quantity": 1,
                "Items": [
                  {
                    "Id": "E1BBB",
                    "ARN": "arn:aws:cloudfront::111122223333:distribution/E1BBB",
                    "DomainName": "d2.cloudfront.net",
                    "DefaultCacheBehavior": {
                      "ViewerProtocolPolicy": "redirect-to-https"
                    },
                    "CacheBehaviors": {
                      "Quantity": 0
                    },
                    "Origins": {
                      "Quantity": 1,
                      "Items": []
                    },
                    "ViewerCertificate": {
                      "MinimumProtocolVersion": "TLSv1.2_2021"
                    },
                    "Restrictions": {
                      "GeoRestriction": {
                        "RestrictionType": "none",
                        "Quantity": 0
                      }
                    },
                    "WebACLId": ""
                  }
                ]
              }
            }
          }
        ]
      }
    ]
  },
  {
    "controlId": "CR-AWS-CLOUDFRONT-002",
    "cases": [
      {
        "name": "fails one behavior allow-all",
        "expected": "fail",
        "records": [
          {
            "collectorId": "aws.cloudfront.list_distributions",
            "exitCode": 0,
            "output": {
              "DistributionList": {
                "Quantity": 1,
                "Items": [
                  {
                    "Id": "E2AAA",
                    "DomainName": "d3.cloudfront.net",
                    "DefaultCacheBehavior": {
                      "ViewerProtocolPolicy": "redirect-to-https"
                    },
                    "CacheBehaviors": {
                      "Quantity": 2,
                      "Items": [
                        {
                          "PathPattern": "/api/*",
                          "ViewerProtocolPolicy": "https-only"
                        },
                        {
                          "PathPattern": "/img/*",
                          "ViewerProtocolPolicy": "allow-all"
                        }
                      ]
                    }
                  }
                ]
              }
            }
          }
        ]
      },
      {
        "name": "passes all secure",
        "expected": "pass",
        "records": [
          {
            "collectorId": "aws.cloudfront.list_distributions",
            "exitCode": 0,
            "output": {
              "DistributionList": {
                "Quantity": 1,
                "Items": [
                  {
                    "Id": "E2BBB",
                    "DomainName": "d4.cloudfront.net",
                    "DefaultCacheBehavior": {
                      "ViewerProtocolPolicy": "redirect-to-https"
                    },
                    "CacheBehaviors": {
                      "Quantity": 1,
                      "Items": [
                        {
                          "PathPattern": "/api/*",
                          "ViewerProtocolPolicy": "https-only"
                        }
                      ]
                    }
                  }
                ]
              }
            }
          }
        ]
      },
      {
        "name": "passes with no extra behaviors",
        "expected": "pass",
        "records": [
          {
            "collectorId": "aws.cloudfront.list_distributions",
            "exitCode": 0,
            "output": {
              "DistributionList": {
                "Quantity": 1,
                "Items": [
                  {
                    "Id": "E2CCC",
                    "DomainName": "d5.cloudfront.net",
                    "DefaultCacheBehavior": {
                      "ViewerProtocolPolicy": "redirect-to-https"
                    },
                    "CacheBehaviors": {
                      "Quantity": 0
                    }
                  }
                ]
              }
            }
          }
        ]
      }
    ]
