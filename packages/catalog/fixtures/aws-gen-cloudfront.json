  {
    "controlId": "CR-AWS-CLOUDFRONT-007",
    "cases": [
      {
        "name": "fails logging disabled",
        "expected": "fail",
        "records": [
          {
            "collectorId": "aws.cloudfront.get_distribution_config",
            "resourceKey": "E7AAA",
            "exitCode": 0,
            "output": {
              "ETag": "E2QWERTY",
              "DistributionConfig": {
                "CallerReference": "ref-1",
                "Comment": "",
                "Enabled": true,
                "DefaultRootObject": "index.html",
                "Logging": {
                  "Enabled": false,
                  "IncludeCookies": false,
                  "Bucket": "",
                  "Prefix": ""
                }
              }
            }
          }
        ]
      },
      {
        "name": "passes logging enabled",
        "expected": "pass",
        "records": [
          {
            "collectorId": "aws.cloudfront.get_distribution_config",
            "resourceKey": "E7BBB",
            "exitCode": 0,
            "output": {
              "ETag": "E2ABCDE",
              "DistributionConfig": {
                "CallerReference": "ref-2",
                "Comment": "",
                "Enabled": true,
                "DefaultRootObject": "index.html",
                "Logging": {
                  "Enabled": true,
                  "IncludeCookies": false,
                  "Bucket": "logs.s3.amazonaws.com",
                  "Prefix": "cf/"
                }
              }
            }
          }
        ]
      },
      {
        "name": "distribution deleted",
        "expected": "not_applicable",
        "records": [
          {
            "collectorId": "aws.cloudfront.get_distribution_config",
            "resourceKey": "E7CCC",
            "exitCode": 254,
            "output": null,
            "errorText": "An error occurred (NoSuchDistribution) when calling the GetDistributionConfig operation: The specified distribution does not exist."
          }
        ]
      }
    ]
  },
