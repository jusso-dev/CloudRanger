[
  {
    "controlId": "CR-AWS-EC2-150",
    "cases": [
      {
        "name": "passes when PostgreSQL is private",
        "expected": "pass",
        "records": [
          {
            "collectorId": "aws.ec2.describe_security_groups",
            "region": "ap-southeast-2",
            "exitCode": 0,
            "output": {
              "SecurityGroups": [
                {
                  "GroupId": "sg-private",
                  "GroupName": "database",
                  "IpPermissions": [
                    {
                      "IpProtocol": "tcp",
                      "FromPort": 5432,
                      "ToPort": 5432,
                      "IpRanges": [{ "CidrIp": "10.0.0.0/16" }],
                      "Ipv6Ranges": []
                    }
                  ]
                }
              ]
            }
          }
        ]
      },
      {
        "name": "fails when PostgreSQL is public",
        "expected": "fail",
        "records": [
          {
            "collectorId": "aws.ec2.describe_security_groups",
            "region": "ap-southeast-2",
            "exitCode": 0,
            "output": {
              "SecurityGroups": [
                {
                  "GroupId": "sg-public",
                  "GroupName": "database",
                  "IpPermissions": [
                    {
                      "IpProtocol": "tcp",
                      "FromPort": 5432,
                      "ToPort": 5432,
                      "IpRanges": [{ "CidrIp": "0.0.0.0/0" }],
                      "Ipv6Ranges": []
                    }
                  ]
                }
              ]
            }
          }
        ]
      },
      {
        "name": "reports denied EC2 inventory access",
        "expected": "error",
        "records": [
          {
            "collectorId": "aws.ec2.describe_security_groups",
            "region": "ap-southeast-2",
            "exitCode": 254,
            "output": null,
            "errorText": "AccessDenied: not authorized to call ec2:DescribeSecurityGroups"
          }
        ]
      },
      { "name": "does not assess without evidence", "expected": "no_results", "records": [] }
    ]
  },
  {
