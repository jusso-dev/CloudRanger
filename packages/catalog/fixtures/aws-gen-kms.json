[
  {
    "controlId": "CR-AWS-KMS-010",
    "cases": [
      {
        "name": "fails wildcard principal",
        "expected": "fail",
        "records": [
          {
            "collectorId": "aws.kms.get_key_policy",
            "region": "us-east-1",
            "resourceKey": "1234abcd-12ab-34cd-56ef-1234567890ab",
            "exitCode": 0,
            "output": {
              "Policy": "{\n  \"Version\": \"2012-10-17\",\n  \"Statement\": [\n    {\n      \"Sid\": \"open\",\n      \"Effect\": \"Allow\",\n      \"Principal\": \"*\",\n      \"Action\": \"kms:Decrypt\",\n      \"Resource\": \"*\"\n    }\n  ]\n}",
              "PolicyName": "default"
            }
          }
        ]
      },
      {
        "name": "passes scoped principal",
        "expected": "pass",
        "records": [
          {
            "collectorId": "aws.kms.get_key_policy",
            "region": "us-east-1",
            "resourceKey": "aaaa1111-12ab-34cd-56ef-1234567890ab",
            "exitCode": 0,
            "output": {
              "Policy": "{\n  \"Version\": \"2012-10-17\",\n  \"Statement\": [\n    {\n      \"Sid\": \"root\",\n      \"Effect\": \"Allow\",\n      \"Principal\": {\"AWS\": \"arn:aws:iam::111122223333:root\"},\n      \"Action\": \"kms:*\",\n      \"Resource\": \"*\"\n    }\n  ]\n}",
              "PolicyName": "default"
            }
          }
        ]
      },
      {
        "name": "error access denied",
        "expected": "error",
        "records": [
          {
            "collectorId": "aws.kms.get_key_policy",
            "region": "us-east-1",
            "resourceKey": "bbbb2222-12ab-34cd-56ef-1234567890ab",
            "exitCode": 254,
            "output": null,
            "errorText": "An error occurred (AccessDeniedException) when calling the GetKeyPolicy operation: User is not authorized to perform kms:GetKeyPolicy"
          }
        ]
      }
    ]
  },
