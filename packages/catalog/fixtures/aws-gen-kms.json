  {
    "controlId": "CR-AWS-KMS-013",
    "cases": [
      {
        "name": "fails rotation disabled",
        "expected": "fail",
        "records": [
          {
            "collectorId": "aws.kms.get_key_rotation_status",
            "region": "us-east-1",
            "resourceKey": "7777aaaa-12ab-34cd-56ef-1234567890ab",
            "exitCode": 0,
            "output": {
              "KeyRotationEnabled": false,
              "KeyId": "7777aaaa-12ab-34cd-56ef-1234567890ab"
            }
          }
        ]
      },
      {
        "name": "passes rotation enabled",
        "expected": "pass",
        "records": [
          {
            "collectorId": "aws.kms.get_key_rotation_status",
            "region": "us-east-1",
            "resourceKey": "8888bbbb-12ab-34cd-56ef-1234567890ab",
            "exitCode": 0,
            "output": {
              "KeyRotationEnabled": true,
              "KeyId": "8888bbbb-12ab-34cd-56ef-1234567890ab",
              "RotationPeriodInDays": 365,
              "NextRotationDate": "2027-01-10T09:00:00-07:00"
            }
          }
        ]
      },
      {
        "name": "not applicable asymmetric key",
        "expected": "not_applicable",
        "records": [
          {
            "collectorId": "aws.kms.get_key_rotation_status",
            "region": "us-east-1",
            "resourceKey": "9999cccc-12ab-34cd-56ef-1234567890ab",
            "exitCode": 254,
            "output": null,
            "errorText": "An error occurred (UnsupportedOperationException) when calling the GetKeyRotationStatus operation: 9999cccc-12ab-34cd-56ef-1234567890ab origin is EXTERNAL which is not valid for this operation."
          }
        ]
      }
    ]
  },
