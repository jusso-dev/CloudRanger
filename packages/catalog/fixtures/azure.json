  {
    "controlId": "CR-AZURE-NETWORK-001",
    "cases": [
      {
        "name": "fails with SSH allowed from any",
        "expected": "fail",
        "records": [
          {
            "collectorId": "azure.network.list_nsgs",
            "exitCode": 0,
            "output": [
              {
                "id": "/subscriptions/s/resourceGroups/rg/providers/Microsoft.Network/networkSecurityGroups/nsg-open",
                "name": "nsg-open",
                "securityRules": [
                  {
                    "name": "allow-ssh",
                    "access": "Allow",
                    "direction": "Inbound",
                    "protocol": "Tcp",
                    "destinationPortRange": "22",
                    "sourceAddressPrefix": "*"
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "name": "fails with SSH in port ranges from Internet tag",
        "expected": "fail",
        "records": [
          {
            "collectorId": "azure.network.list_nsgs",
            "exitCode": 0,
            "output": [
              {
                "id": "/subscriptions/s/resourceGroups/rg/providers/Microsoft.Network/networkSecurityGroups/nsg-ranges",
                "name": "nsg-ranges",
                "securityRules": [
                  {
                    "name": "allow-mgmt",
                    "access": "Allow",
                    "direction": "Inbound",
                    "protocol": "*",
                    "destinationPortRanges": ["20-25", "443"],
                    "sourceAddressPrefix": "Internet"
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "name": "passes with restricted source",
        "expected": "pass",
        "records": [
          {
            "collectorId": "azure.network.list_nsgs",
            "exitCode": 0,
            "output": [
              {
                "id": "/subscriptions/s/resourceGroups/rg/providers/Microsoft.Network/networkSecurityGroups/nsg-restricted",
                "name": "nsg-restricted",
                "securityRules": [
                  {
                    "name": "allow-ssh-office",
                    "access": "Allow",
                    "direction": "Inbound",
                    "protocol": "Tcp",
                    "destinationPortRange": "22",
                    "sourceAddressPrefix": "203.0.113.0/24"
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "name": "passes when rule is deny",
        "expected": "pass",
        "records": [
          {
            "collectorId": "azure.network.list_nsgs",
            "exitCode": 0,
            "output": [
              {
                "id": "/subscriptions/s/resourceGroups/rg/providers/Microsoft.Network/networkSecurityGroups/nsg-deny",
                "name": "nsg-deny",
                "securityRules": [
                  {
                    "name": "deny-ssh",
                    "access": "Deny",
                    "direction": "Inbound",
                    "protocol": "Tcp",
                    "destinationPortRange": "22",
                    "sourceAddressPrefix": "*"
                  }
                ]
              }
            ]
          }
        ]
      }
    ]
  },
  {
