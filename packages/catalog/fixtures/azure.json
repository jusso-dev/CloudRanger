  {
    "controlId": "CR-AZURE-KEYVAULT-001",
    "cases": [
      {
        "name": "passes with purge protection",
        "expected": "pass",
        "records": [
          {
            "collectorId": "azure.keyvault.show",
            "resourceKey": "kv-prod",
            "exitCode": 0,
            "output": {
              "name": "kv-prod",
              "properties": { "enableSoftDelete": true, "enablePurgeProtection": true }
            }
          }
        ]
      },
      {
        "name": "fails without purge protection",
        "expected": "fail",
        "records": [
          {
            "collectorId": "azure.keyvault.show",
            "resourceKey": "kv-dev",
            "exitCode": 0,
            "output": { "name": "kv-dev", "properties": { "enableSoftDelete": true } }
          }
        ]
      }
    ]
  },
  {
    "controlId": "CR-AZURE-KEYVAULT-002",
    "cases": [
      {
        "name": "passes with soft delete",
        "expected": "pass",
        "records": [
          {
            "collectorId": "azure.keyvault.show",
            "resourceKey": "kv-prod",
            "exitCode": 0,
            "output": { "name": "kv-prod", "properties": { "enableSoftDelete": true } }
          }
        ]
      },
      {
        "name": "fails without soft delete",
        "expected": "fail",
        "records": [
          {
            "collectorId": "azure.keyvault.show",
            "resourceKey": "kv-legacy",
            "exitCode": 0,
            "output": { "name": "kv-legacy", "properties": { "enableSoftDelete": false } }
          }
        ]
      }
    ]
  },
