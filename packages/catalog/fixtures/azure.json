[
  {
    "controlId": "CR-AZURE-STORAGE-001",
    "cases": [
      {
        "name": "passes when HTTPS-only enabled",
        "expected": "pass",
        "records": [
          {
            "collectorId": "azure.storage.list_accounts",
            "exitCode": 0,
            "output": [{ "name": "prodstorage", "enableHttpsTrafficOnly": true }]
          }
        ]
      },
      {
        "name": "fails when HTTP allowed",
        "expected": "fail",
        "records": [
          {
            "collectorId": "azure.storage.list_accounts",
            "exitCode": 0,
            "output": [{ "name": "legacystorage", "enableHttpsTrafficOnly": false }]
          }
        ]
      }
    ]
  },
  {
    "controlId": "CR-AZURE-STORAGE-002",
    "cases": [
      {
        "name": "passes when public blob access disabled",
        "expected": "pass",
        "records": [
          {
            "collectorId": "azure.storage.list_accounts",
            "exitCode": 0,
            "output": [{ "name": "prodstorage", "allowBlobPublicAccess": false }]
          }
        ]
      },
      {
        "name": "passes when property absent (modern default deny)",
        "expected": "pass",
        "records": [
          {
            "collectorId": "azure.storage.list_accounts",
            "exitCode": 0,
            "output": [{ "name": "newstorage" }]
          }
        ]
      },
      {
        "name": "fails when public blob access allowed",
        "expected": "fail",
        "records": [
          {
            "collectorId": "azure.storage.list_accounts",
            "exitCode": 0,
            "output": [{ "name": "openstorage", "allowBlobPublicAccess": true }]
          }
        ]
      }
    ]
  },
  {
