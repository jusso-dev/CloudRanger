{
  "name": "cloudranger",
  "version": "0.1.0",
  "private": true,
  "description": "Open-source, local-first, agent-driven multi-cloud CSPM. MCP server + deterministic control engine + SQLite finding history.",
  "license": "Apache-2.0",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "build": "turbo run build",
    "test": "pnpm prowler:coverage:validate && turbo run test",
    "lint": "eslint .",
    "typecheck": "turbo run typecheck",
    "format": "prettier --write \"**/*.{ts,md,json,yaml,yml}\"",
    "format:check": "prettier --check \"**/*.{ts,md,json,yaml,yml}\"",
    "catalog:validate": "node apps/cli/dist/main.js catalog validate",
    "catalog:test": "node apps/cli/dist/main.js catalog test",
    "prowler:coverage:sync": "node scripts/prowler-coverage.mjs sync",
    "prowler:coverage:validate": "node scripts/prowler-coverage.mjs validate",
    "prowler:coverage:report": "node scripts/prowler-coverage.mjs report",
    "compliance:mappings:validate": "node scripts/compliance-mappings-validate.mjs",
    "ism:oscal:sync": "node scripts/ism-oscal-sync.mjs",
    "examples:reports": "node scripts/generate-example-reports.mjs output/pdf"
  },
  "devDependencies": {
    "@eslint/js": "^9.30.0",
    "@types/node": "^24.0.0",
    "eslint": "^9.30.0",
    "globals": "^17.7.0",
    "prettier": "^3.6.0",
    "turbo": "^2.5.0",
    "typescript": "^5.9.0",
    "typescript-eslint": "^8.35.0",
    "vitest": "^3.2.0",
    "yaml": "^2.9.0"
  },
  "pnpm": {
    "overrides": {
      "esbuild": "0.28.1"
    },
    "onlyBuiltDependencies": [
      "better-sqlite3"
    ]
  }
}
